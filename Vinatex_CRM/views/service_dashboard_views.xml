<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_complaint_by_severity" model="ir.actions.act_window">
        <field name="name">Khiếu nại theo mức độ</field>
        <field name="res_model">crm.service.complaint.ticket</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="context">{'group_by': 'severity'}</field>
    </record>

    <record id="action_complaint_by_state" model="ir.actions.act_window">
        <field name="name">Khiếu nại theo trạng thái</field>
        <field name="res_model">crm.service.complaint.ticket</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="context">{'group_by': 'state'}</field>
    </record>

    <record id="action_complaint_sla_late" model="ir.actions.act_window">
        <field name="name">Khiếu nại trễ SLA</field>
        <field name="res_model">crm.service.complaint.ticket</field>
        <field name="view_mode">tree,graph,pivot,form</field>
        <field name="domain">[('sla_status', '=', 'late')]</field>
        <field name="context">{'group_by': 'sale_user_id'}</field>
    </record>

    <record id="action_customer_satisfaction" model="ir.actions.act_window">
        <field name="name">Mức độ hài lòng</field>
        <field name="res_model">crm.service.complaint.ticket</field>
        <field name="view_mode">pivot,graph,tree,form</field>
        <field name="domain">[('satisfaction_score', '!=', False)]</field>
        <field name="context">{'group_by': 'sale_user_id'}</field>
    </record>

    <record id="action_crm_kpi_leads" model="ir.actions.act_window">
        <field name="name">Bảng KPI CRM</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">graph,pivot,tree,form</field>
        <field name="context">{'group_by': 'user_id'}</field>
    </record>

    <record id="action_fail_reason_analysis" model="ir.actions.act_window">
        <field name="name">Phân tích lý do thất bại</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">pivot,graph,tree,form</field>
        <field name="domain">[('fail_reason', '!=', False)]</field>
        <field name="context">{'group_by': 'fail_reason'}</field>
    </record>
</odoo>
