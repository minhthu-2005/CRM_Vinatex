    <record id="action_crm_lead_management" model="ir.actions.act_window">
        <field name="name">Quản lý Lead &amp; cơ hội</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,kanban,form,graph,pivot</field>
        <field name="view_id" ref="view_crm_lead_management_list"/>
        <field name="domain">[('type', 'in', ['lead', 'opportunity'])]</field>
        <field name="context">{'default_type': 'lead', 'search_default_active_leads': 1}</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo lead hoặc cơ hội mới trực tiếp trên CRM
            </p>
            <p>
                Lead phải có đầy đủ thông tin khách hàng, nguồn lead, người phụ trách và nhu cầu sản phẩm ban đầu.
            </p>
        </field>
    </record>
</odoo>
