<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lost_reason_analytics_tree" model="ir.ui.view">
        <field name="name">crm.lost.reason.analytics.list</field>
        <field name="model">crm.lost.reason.analytics</field>
        <field name="arch" type="xml">
            <tree string="Theo dõi cơ hội thất bại">
                <field name="lead_name"/>
                <field name="lost_reason_id"/>
                <field name="user_id"/>
                <field name="expected_revenue" sum="Tổng doanh thu kỳ vọng"/>
                <field name="lost_date"/>
            </tree>
        </field>
    </record>
    <record id="action_crm_lost_reason_analytics" model="ir.actions.act_window">
        <field name="name">Theo dõi cơ hội thất bại</field>
        <field name="res_model">crm.lost.reason.analytics</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>

