<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_crm_lead_duplicate_review" model="ir.actions.act_window">
        <field name="name">Lead nghi trùng</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('type', 'in', ['lead', 'opportunity']), ('duplicate_state', 'in', ['similar', 'exact'])]</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
    </record>

    <record id="action_crm_lead_missing_data" model="ir.actions.act_window">
        <field name="name">Lead thiếu dữ liệu</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('type', 'in', ['lead', 'opportunity']), ('data_quality_state', 'in', ['missing', 'invalid'])]</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
    </record>

    <record id="action_crm_lead_inactive_archived" model="ir.actions.act_window">
        <field name="name">Lead ngừng tương tác / đã lưu trữ</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('type', 'in', ['lead', 'opportunity']), ('active', '=', False)]</field>
        <field name="context">{'active_test': False}</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
    </record>

    <record id="action_crm_tong_hop_dashboard" model="ir.actions.client">
        <field name="name">Tổng quan CRM</field>
        <field name="tag">crm_tong_hop.dashboard</field>
    </record>

