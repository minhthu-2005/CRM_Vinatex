<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_form_inherit_unified_workflow" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.unified.workflow</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_cskh_profiles" type="object" class="oe_stat_button" icon="fa-heart">
                    <field name="cskh_profile_count" widget="statinfo" string="CSKH"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_create_cskh_profile" string="Tạo CSKH" type="object"/>
                <button name="action_create_complaint_ticket" string="Tạo khiếu nại" type="object" invisible="not partner_id"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Quy trình CRM tổng">
                    <group>
                        <group string="Trạng thái liên thông">
                            <field name="unified_crm_state" widget="badge"/>
                            <field name="latest_cskh_profile_id" readonly="1"/>
                            <field name="complaint_count" readonly="1"/>
                        </group>
                        <group string="Hành động nhanh">
                            <button name="action_create_cskh_profile" string="Ghi nhận chăm sóc" type="object" class="btn-primary"/>
                            <button name="action_create_complaint_ticket" string="Mở phiếu khiếu nại" type="object" invisible="not partner_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
