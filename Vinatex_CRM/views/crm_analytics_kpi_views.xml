<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_analytics_kpi_tree" model="ir.ui.view">
        <field name="name">crm.analytics.kpi.list</field>
        <field name="model">crm.analytics.kpi</field>
        <field name="arch" type="xml">
            <tree string="Tổng quan chỉ số CRM" create="false" edit="false" delete="false">
                <field name="lead_count" sum="Tổng Lead"/>
                <field name="lead_id"/>
                <field name="lead_name"/>
                <field name="stage_id"/>
                <field name="salesperson_id"/>
                <field name="expected_revenue" sum="Tổng doanh thu kỳ vọng"/>
                <field name="probability" avg="Xác suất trung bình"/>
                <field name="event_type"/>
            </tree>
        </field>
    </record>
    <record id="view_crm_analytics_kpi_graph" model="ir.ui.view">
        <field name="name">crm.analytics.kpi.graph</field>
        <field name="model">crm.analytics.kpi</field>
        <field name="arch" type="xml">
            <graph string="Tổng quan chỉ số CRM" type="bar">
                <field name="salesperson_id"/>
                <field name="lead_count" type="measure"/>
                <field name="expected_revenue" type="measure"/>
                <field name="probability" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="view_crm_analytics_kpi_pivot" model="ir.ui.view">
        <field name="name">crm.analytics.kpi.pivot</field>
        <field name="model">crm.analytics.kpi</field>
        <field name="arch" type="xml">
            <pivot string="Tổng quan chỉ số CRM">
                <field name="salesperson_id" type="row"/>
                <field name="stage_id" type="col"/>
                <field name="lead_count" type="measure"/>
                <field name="expected_revenue" type="measure"/>
                <field name="probability" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="action_crm_analytics_kpi" model="ir.actions.act_window">
        <field name="name">Tổng quan chỉ số CRM</field>
        <field name="res_model">crm.analytics.kpi</field>
        <field name="view_mode">tree,graph,pivot</field>
    </record>
</odoo>

