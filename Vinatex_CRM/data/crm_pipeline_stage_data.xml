<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="stage_new_lead" model="crm.stage">
        <field name="name">Lead mới</field>
        <field name="sequence">1</field>
        <field name="requirements">Lead mới phát sinh, cần xác nhận nhu cầu và bổ sung đủ thông tin khách hàng.</field>
    </record>

    <record id="stage_qualified" model="crm.stage">
        <field name="name">Đã xác thực nhu cầu</field>
        <field name="sequence">2</field>
        <field name="requirements">Đã xác nhận khách hàng có nhu cầu thực tế, sản phẩm, số lượng và thời điểm dự kiến.</field>
    </record>

    <record id="stage_proposal" model="crm.stage">
        <field name="name">Đã gửi báo giá</field>
        <field name="sequence">3</field>
        <field name="requirements">Đã gửi báo giá, mẫu vải hoặc đề xuất phương án sản xuất cho khách hàng.</field>
    </record>

    <record id="stage_negotiation" model="crm.stage">
        <field name="name">Đang thương lượng</field>
        <field name="sequence">4</field>
        <field name="requirements">Đang thương lượng giá, tiến độ, tiêu chuẩn chất lượng hoặc điều khoản thanh toán.</field>
    </record>

    <record id="stage_won" model="crm.stage">
        <field name="name">Chốt thành công</field>
        <field name="sequence">5</field>
        <field name="is_won" eval="True"/>
        <field name="fold" eval="True"/>
        <field name="requirements">Cơ hội đã chốt thành công và cần chuyển sang chăm sóc sau bán.</field>
    </record>

    <record id="stage_lost" model="crm.stage">
        <field name="name">Thất bại</field>
        <field name="sequence">6</field>
        <field name="fold" eval="True"/>
        <field name="requirements">Cơ hội không thành công, cần ghi nhận lý do để phân tích và chăm sóc lại khi phù hợp.</field>
    </record>

    <record id="stage_dormant" model="crm.stage">
        <field name="name">Lâu chưa tương tác</field>
        <field name="sequence">7</field>
        <field name="fold" eval="True"/>
        <field name="requirements">Khách hàng chưa phản hồi trong thời gian dài, cần đưa vào danh sách chăm sóc lại.</field>
    </record>
</odoo>
