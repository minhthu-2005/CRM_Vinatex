<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_crm_lead_duplicate_review" model="ir.actions.act_window">
        <field name="name">Lead nghi trùng</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'lead'), ('duplicate_state', 'in', ['similar', 'exact'])]</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
    </record>

    <record id="action_crm_lead_missing_data" model="ir.actions.act_window">
        <field name="name">Lead thiếu dữ liệu</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'lead'), ('data_quality_state', 'in', ['missing', 'invalid'])]</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
    </record>

    <record id="action_crm_lead_inactive_archived" model="ir.actions.act_window">
        <field name="name">Lead inactive / archived</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'lead'), ('active', '=', False)]</field>
        <field name="context">{'active_test': False}</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
    </record>

    <menuitem id="menu_crm_lead_management_root" name="Quản lý Lead CRM" sequence="36"/>
    <menuitem id="menu_crm_lead_management_leads" name="Lead" parent="menu_crm_lead_management_root" action="action_crm_lead_management" sequence="10"/>
    <menuitem id="menu_crm_lead_management_approvals" name="Phê duyệt dữ liệu" parent="menu_crm_lead_management_root" action="action_crm_lead_data_approval" sequence="20"/>
    <menuitem id="menu_crm_lead_management_reports" name="Kiểm soát dữ liệu" parent="menu_crm_lead_management_root" sequence="30"/>
    <menuitem id="menu_crm_lead_duplicate_review" name="Lead nghi trùng" parent="menu_crm_lead_management_reports" action="action_crm_lead_duplicate_review" sequence="10"/>
    <menuitem id="menu_crm_lead_missing_data" name="Lead thiếu dữ liệu" parent="menu_crm_lead_management_reports" action="action_crm_lead_missing_data" sequence="20"/>
    <menuitem id="menu_crm_lead_inactive_archived" name="Lead inactive / archived" parent="menu_crm_lead_management_reports" action="action_crm_lead_inactive_archived" sequence="30"/>
</odoo>
