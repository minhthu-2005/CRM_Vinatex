<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_management_list" model="ir.ui.view">
        <field name="name">crm.lead.management.list</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <list string="Quản lý Lead" decoration-danger="duplicate_state == 'exact' or data_quality_state == 'invalid'" decoration-warning="duplicate_state == 'similar' or data_quality_state == 'missing'" decoration-muted="not active">
                <field name="name"/>
                <field name="partner_name"/>
                <field name="contact_name"/>
                <field name="email_from"/>
                <field name="phone"/>
                <field name="website" optional="hide"/>
                <field name="source_id"/>
                <field name="user_id"/>
                <field name="stage_id"/>
                <field name="duplicate_state" widget="badge" decoration-success="duplicate_state == 'clean'" decoration-warning="duplicate_state == 'similar'" decoration-danger="duplicate_state == 'exact'"/>
                <field name="data_quality_state" widget="badge" decoration-success="data_quality_state == 'valid'" decoration-warning="data_quality_state == 'missing'" decoration-danger="data_quality_state == 'invalid'"/>
                <field name="last_interaction_date"/>
                <field name="inactive_archive_date"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_crm_lead_management_search" model="ir.ui.view">
        <field name="name">crm.lead.management.search</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <search string="Quản lý Lead">
                <field name="name"/>
                <field name="partner_name"/>
                <field name="contact_name"/>
                <field name="email_from"/>
                <field name="phone"/>
                <field name="source_id"/>
                <field name="user_id"/>
                <filter name="active_leads" string="Đang hoạt động" domain="[('active', '=', True)]"/>
                <filter name="archived_leads" string="Đã archive" domain="[('active', '=', False)]"/>
                <filter name="missing_data" string="Thiếu dữ liệu" domain="[('data_quality_state', '=', 'missing')]"/>
                <filter name="invalid_data" string="Sai định dạng" domain="[('data_quality_state', '=', 'invalid')]"/>
                <filter name="similar_duplicate" string="Nghi trùng" domain="[('duplicate_state', '=', 'similar')]"/>
                <filter name="exact_duplicate" string="Trùng hoàn toàn" domain="[('duplicate_state', '=', 'exact')]"/>
                <separator/>
                <filter name="group_stage" string="Pipeline" context="{'group_by': 'stage_id'}"/>
                <filter name="group_owner" string="Sales Owner" context="{'group_by': 'user_id'}"/>
                <filter name="group_source" string="Nguồn lead" context="{'group_by': 'source_id'}"/>
                <filter name="group_quality" string="Chất lượng dữ liệu" context="{'group_by': 'data_quality_state'}"/>
            </search>
        </field>
    </record>

    <record id="crm_lead_view_form_inherit_lead_management" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.lead.management</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_duplicate_leads" type="object" class="oe_stat_button" icon="fa-copy" invisible="duplicate_count == 0">
                    <field name="duplicate_count" widget="statinfo" string="Nghi trùng"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_open_transfer_owner_wizard" string="Chuyển phụ trách" type="object" invisible="type != 'lead'"/>
                <button name="action_mark_interaction_today" string="Ghi nhận tương tác" type="object" invisible="type != 'lead'"/>
                <button name="action_request_merge_approval" string="Yêu cầu merge" type="object" invisible="duplicate_count == 0 or type != 'lead'"/>
                <button name="action_request_delete_approval" string="Yêu cầu xóa" type="object" invisible="type != 'lead'"/>
            </xpath>
            <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='country_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Quản lý dữ liệu Lead">
                    <group>
                        <group string="Thông tin bắt buộc">
                            <field name="partner_name" required="1"/>
                            <field name="contact_name" required="1"/>
                            <field name="email_from" required="1"/>
                            <field name="phone" required="1"/>
                            <field name="website" required="1"/>
                            <field name="source_id" required="1"/>
                            <field name="user_id" required="1"/>
                            <field name="initial_product_requirement" required="1"/>
                        </group>
                        <group string="Kiểm soát dữ liệu">
                            <field name="data_quality_state" widget="badge" decoration-success="data_quality_state == 'valid'" decoration-warning="data_quality_state == 'missing'" decoration-danger="data_quality_state == 'invalid'"/>
                            <field name="missing_required_fields" readonly="1"/>
                            <field name="duplicate_state" widget="badge" decoration-success="duplicate_state == 'clean'" decoration-warning="duplicate_state == 'similar'" decoration-danger="duplicate_state == 'exact'"/>
                            <field name="duplicate_lead_ids" widget="many2many_tags" readonly="1"/>
                            <field name="last_interaction_date"/>
                            <field name="inactive_archive_date" readonly="1"/>
                            <field name="archived_by_cron" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_crm_lead_management" model="ir.actions.act_window">
        <field name="name">Quản lý Lead</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,kanban,form,graph,pivot</field>
        <field name="domain">[('type', '=', 'lead')]</field>
        <field name="context">{'default_type': 'lead', 'search_default_active_leads': 1}</field>
        <field name="search_view_id" ref="view_crm_lead_management_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo lead mới trực tiếp trên CRM
            </p>
            <p>
                Lead phải có đầy đủ thông tin khách hàng, nguồn lead, Sales Owner và nhu cầu sản phẩm ban đầu.
            </p>
        </field>
    </record>
</odoo>
