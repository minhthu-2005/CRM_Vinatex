<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_data_approval_list" model="ir.ui.view">
        <field name="name">crm.lead.data.approval.list</field>
        <field name="model">crm.lead.data.approval</field>
        <field name="arch" type="xml">
            <list string="Yêu cầu phê duyệt dữ liệu CRM" decoration-info="state == 'submitted'" decoration-success="state in ('approved', 'executed')" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="request_type"/>
                <field name="lead_id"/>
                <field name="duplicate_lead_id"/>
                <field name="requester_id"/>
                <field name="manager_id"/>
                <field name="state" widget="badge" decoration-muted="state == 'draft'" decoration-info="state == 'submitted'" decoration-success="state in ('approved', 'executed')" decoration-danger="state == 'rejected'"/>
                <field name="requested_date"/>
                <field name="approved_date"/>
            </list>
        </field>
    </record>

    <record id="view_crm_lead_data_approval_form" model="ir.ui.view">
        <field name="name">crm.lead.data.approval.form</field>
        <field name="model">crm.lead.data.approval</field>
        <field name="arch" type="xml">
            <form string="Yêu cầu phê duyệt dữ liệu CRM">
                <header>
                    <button name="action_submit" string="Gửi phê duyệt" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Phê duyệt" type="object" class="btn-primary" groups="sales_team.group_sale_manager" invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Từ chối" type="object" groups="sales_team.group_sale_manager" invisible="state != 'submitted'"/>
                    <button name="action_execute" string="Thực hiện" type="object" class="btn-primary" groups="sales_team.group_sale_manager" invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected,executed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <span class="text-muted">
                            <field name="name"/>
                        </span>
                    </div>
                    <group>
                        <group string="Thông tin yêu cầu">
                            <field name="request_type"/>
                            <field name="lead_id"/>
                            <field name="duplicate_lead_id" invisible="request_type != 'merge'"/>
                            <field name="requester_id" readonly="1"/>
                            <field name="requested_date" readonly="1"/>
                        </group>
                        <group string="Phê duyệt">
                            <field name="manager_id" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lý do yêu cầu">
                            <field name="reason"/>
                        </page>
                        <page string="Ghi chú phê duyệt">
                            <field name="decision_note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_crm_lead_data_approval_search" model="ir.ui.view">
        <field name="name">crm.lead.data.approval.search</field>
        <field name="model">crm.lead.data.approval</field>
        <field name="arch" type="xml">
            <search string="Yêu cầu phê duyệt dữ liệu CRM">
                <field name="name"/>
                <field name="lead_id"/>
                <field name="duplicate_lead_id"/>
                <field name="requester_id"/>
                <filter name="submitted" string="Chờ phê duyệt" domain="[('state', '=', 'submitted')]"/>
                <filter name="approved" string="Đã phê duyệt" domain="[('state', '=', 'approved')]"/>
                <filter name="merge" string="Merge dữ liệu" domain="[('request_type', '=', 'merge')]"/>
                <filter name="delete" string="Xóa dữ liệu" domain="[('request_type', '=', 'delete')]"/>
                <separator/>
                <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                <filter name="group_type" string="Loại yêu cầu" context="{'group_by': 'request_type'}"/>
                <filter name="group_requester" string="Người yêu cầu" context="{'group_by': 'requester_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_crm_lead_data_approval" model="ir.actions.act_window">
        <field name="name">Phê duyệt dữ liệu CRM</field>
        <field name="res_model">crm.lead.data.approval</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_crm_lead_data_approval_search"/>
        <field name="context">{'search_default_submitted': 1}</field>
    </record>
</odoo>
