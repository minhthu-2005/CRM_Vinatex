<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_feedback_form_list" model="ir.ui.view">
        <field name="name">crm.service.feedback.form.list</field>
        <field name="model">crm.service.feedback.form</field>
        <field name="arch" type="xml">
            <list string="Biểu mẫu phản hồi" decoration-muted="state in ('closed', 'archived')">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state in ('closed', 'archived')"/>
                <field name="user_id"/>
                <field name="request_count"/>
                <field name="response_count"/>
                <field name="average_score"/>
                <field name="satisfaction_rate"/>
            </list>
        </field>
    </record>

    <record id="view_feedback_form_form" model="ir.ui.view">
        <field name="name">crm.service.feedback.form.form</field>
        <field name="model">crm.service.feedback.form</field>
        <field name="arch" type="xml">
            <form string="Biểu mẫu phản hồi">
                <header>
                    <button name="action_activate" type="object" string="Kích hoạt" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_send_requests" type="object" string="Gửi cho khách hàng" class="btn-primary" invisible="state in ('closed', 'archived')"/>
                    <button name="action_close" type="object" string="Đóng" invisible="state not in ('draft', 'active')"/>
                    <button name="action_reset_to_draft" type="object" string="Đưa về nháp" invisible="state != 'closed'"/>
                    <button name="action_archive" type="object" string="Lưu trữ" invisible="state == 'archived'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed,archived"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_requests" type="object" class="oe_stat_button" icon="fa-envelope">
                            <field name="request_count" widget="statinfo" string="Yêu cầu"/>
                        </button>
                        <button name="action_view_requests" type="object" class="oe_stat_button" icon="fa-check-square-o">
                            <field name="response_count" widget="statinfo" string="Phản hồi"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Tên biểu mẫu phản hồi"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Tổng hợp">
                            <field name="average_score"/>
                            <field name="satisfaction_rate"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Câu hỏi">
                            <field name="question_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="question_type"/>
                                    <field name="required"/>
                                    <field name="max_score" invisible="question_type not in ('rating', 'satisfaction')"/>
                                </list>
                            </field>
                        </page>
                        <page string="Người nhận">
                            <field name="partner_ids" widget="many2many_tags" placeholder="Chọn khách hàng nhận biểu mẫu này"/>
                        </page>
                        <page string="Mô tả">
                            <field name="description" placeholder="Mục đích và bối cảnh của biểu mẫu phản hồi"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_feedback_form_search" model="ir.ui.view">
        <field name="name">crm.service.feedback.form.search</field>
        <field name="model">crm.service.feedback.form</field>
        <field name="arch" type="xml">
            <search string="Biểu mẫu phản hồi">
                <field name="name"/>
                <field name="user_id"/>
                <filter name="active" string="Đang hoạt động" domain="[('state', '=', 'active')]"/>
                <filter name="draft" string="Nháp" domain="[('state', '=', 'draft')]"/>
                <filter name="closed" string="Đã đóng" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                <filter name="group_responsible" string="Người phụ trách" context="{'group_by': 'user_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_feedback_form" model="ir.actions.act_window">
        <field name="name">Biểu mẫu phản hồi</field>
        <field name="res_model">crm.service.feedback.form</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_feedback_form_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo biểu mẫu phản hồi khách hàng
            </p>
            <p>
                Xây dựng khảo sát về chất lượng dịch vụ, mức độ hài lòng, thái độ nhân viên, tốc độ xử lý, chất lượng sản phẩm và ý kiến đóng góp.
            </p>
        </field>
    </record>

    <record id="view_feedback_request_list" model="ir.ui.view">
        <field name="name">crm.service.feedback.request.list</field>
        <field name="model">crm.service.feedback.request</field>
        <field name="arch" type="xml">
            <list string="Yêu cầu phản hồi" decoration-danger="is_negative" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="form_id"/>
                <field name="partner_id"/>
                <field name="state" widget="badge" decoration-info="state == 'sent'" decoration-success="state == 'answered'" decoration-muted="state in ('draft', 'cancelled')"/>
                <field name="sent_date"/>
                <field name="answered_date"/>
                <field name="staff_reply_sent_date"/>
                <field name="average_score"/>
                <field name="satisfaction_level" widget="badge" decoration-success="satisfaction_level == 'satisfied'" decoration-warning="satisfaction_level == 'neutral'" decoration-danger="satisfaction_level == 'dissatisfied'"/>
                <field name="is_negative"/>
                <field name="complaint_ticket_id"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_feedback_request_kanban" model="ir.ui.view">
        <field name="name">crm.service.feedback.request.kanban</field>
        <field name="model">crm.service.feedback.request</field>
        <field name="arch" type="xml">
            <kanban string="Luồng phản hồi" default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="form_id"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="average_score"/>
                <field name="satisfaction_level"/>
                <field name="is_negative"/>
                <field name="complaint_ticket_id"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="fw-bold text-primary" t-out="record.name.value"/>
                            <span t-if="record.is_negative.raw_value" class="badge text-bg-danger">Tiêu cực</span>
                        </div>
                        <div class="fw-semibold mb-1" t-out="record.form_id.value"/>
                        <div class="text-muted small mb-3" t-if="record.partner_id.value">
                            <i class="fa fa-user me-1" title="Khách hàng"/>
                            <span t-out="record.partner_id.value"/>
                        </div>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span t-if="record.average_score.raw_value">
                                <i class="fa fa-star text-warning me-1" title="Điểm trung bình"/>
                                <span t-out="record.average_score.value"/>
                            </span>
                            <span t-if="record.complaint_ticket_id.value" class="badge text-bg-light">
                                Đã tạo khiếu nại
                            </span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_feedback_request_form" model="ir.ui.view">
        <field name="name">crm.service.feedback.request.form</field>
        <field name="model">crm.service.feedback.request</field>
        <field name="arch" type="xml">
            <form string="Yêu cầu phản hồi">
                <header>
                    <button name="action_send_email" type="object" string="Gửi email" class="btn-primary" invisible="state in ('answered', 'cancelled')"/>
                    <button name="action_open_staff_reply_wizard" type="object" string="Soạn thư phản hồi" class="btn-primary" invisible="state != 'answered'"/>
                    <button name="action_create_complaint" type="object" string="Tạo khiếu nại" class="btn-primary" invisible="not is_negative or complaint_ticket_id"/>
                    <button name="action_cancel" type="object" string="Hủy" invisible="state in ('answered', 'cancelled')"/>
                    <button name="action_reset_to_draft" type="object" string="Đưa về nháp" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,answered,cancelled"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Tiêu cực" bg_color="text-bg-danger" invisible="not is_negative"/>
                    <div class="oe_title">
                        <span class="text-muted">
                            <field name="name"/>
                        </span>
                        <h1>
                            <field name="form_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Khách hàng">
                            <field name="partner_id"/>
                            <field name="email"/>
                            <field name="lead_id"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Theo dõi">
                            <field name="sent_date"/>
                            <field name="answered_date"/>
                            <field name="due_date"/>
                            <field name="average_score"/>
                            <field name="satisfaction_level" widget="badge" decoration-success="satisfaction_level == 'satisfied'" decoration-warning="satisfaction_level == 'neutral'" decoration-danger="satisfaction_level == 'dissatisfied'"/>
                            <field name="complaint_ticket_id"/>
                            <field name="access_token" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Câu trả lời">
                            <field name="line_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="question_id" readonly="1"/>
                                    <field name="question_type" readonly="1"/>
                                    <field name="required" readonly="1"/>
                                    <field name="rating_value" invisible="question_type not in ('rating', 'satisfaction')"/>
                                    <field name="boolean_value" invisible="question_type != 'boolean'"/>
                                    <field name="text_value" invisible="question_type != 'text'"/>
                                    <field name="score" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú bổ sung">
                            <group>
                                <group string="Ý kiến khách hàng">
                                    <field name="additional_note" readonly="1" placeholder="Ý kiến bổ sung khách hàng nhập trên portal/email"/>
                                </group>
                                <group string="Trả lời khách hàng">
                                    <field name="staff_reply_subject" readonly="1"/>
                                    <field name="staff_reply" readonly="1" placeholder="Chưa gửi thư phản hồi khách hàng"/>
                                    <field name="staff_reply_user_id" readonly="1"/>
                                    <field name="staff_reply_date" readonly="1"/>
                                    <field name="staff_reply_sent_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_feedback_reply_wizard_form" model="ir.ui.view">
        <field name="name">crm.service.feedback.reply.wizard.form</field>
        <field name="model">crm.service.feedback.reply.wizard</field>
        <field name="arch" type="xml">
            <form string="Soạn thư phản hồi khách hàng">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="subject"/>
                    <field name="body" placeholder="Nhập nội dung thư phản hồi gửi cho khách hàng..." nolabel="1"/>
                </group>
                <footer>
                    <button name="action_send_reply" string="Gửi thư" type="object" class="btn-primary"/>
                    <button string="Hủy" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_feedback_request_search" model="ir.ui.view">
        <field name="name">crm.service.feedback.request.search</field>
        <field name="model">crm.service.feedback.request</field>
        <field name="arch" type="xml">
            <search string="Yêu cầu phản hồi">
                <field name="name"/>
                <field name="form_id"/>
                <field name="partner_id"/>
                <field name="lead_id"/>
                <field name="user_id"/>
                <filter name="sent" string="Đã gửi" domain="[('state', '=', 'sent')]"/>
                <filter name="answered" string="Đã phản hồi" domain="[('state', '=', 'answered')]"/>
                <filter name="negative" string="Tiêu cực" domain="[('is_negative', '=', True)]"/>
                <filter name="with_complaint" string="Có khiếu nại" domain="[('complaint_ticket_id', '!=', False)]"/>
                <separator/>
                <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                <filter name="group_form" string="Biểu mẫu" context="{'group_by': 'form_id'}"/>
                <filter name="group_customer" string="Khách hàng" context="{'group_by': 'partner_id'}"/>
                <filter name="group_satisfaction" string="Mức độ hài lòng" context="{'group_by': 'satisfaction_level'}"/>
                <filter name="group_responsible" string="Người phụ trách" context="{'group_by': 'user_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_feedback_request_graph" model="ir.ui.view">
        <field name="name">crm.service.feedback.request.graph</field>
        <field name="model">crm.service.feedback.request</field>
        <field name="arch" type="xml">
            <graph string="Phân tích phản hồi" type="bar">
                <field name="form_id"/>
                <field name="average_score" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_feedback_request_pivot" model="ir.ui.view">
        <field name="name">crm.service.feedback.request.pivot</field>
        <field name="model">crm.service.feedback.request</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích phản hồi">
                <field name="form_id" type="row"/>
                <field name="satisfaction_level" type="col"/>
                <field name="average_score" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_feedback_request" model="ir.actions.act_window">
        <field name="name">Yêu cầu phản hồi</field>
        <field name="res_model">crm.service.feedback.request</field>
        <field name="view_mode">kanban,list,form,graph,pivot</field>
        <field name="search_view_id" ref="view_feedback_request_search"/>
        <field name="context">{'search_default_sent': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Gửi biểu mẫu phản hồi cho khách hàng
            </p>
            <p>
                Theo dõi trạng thái gửi, phản hồi, phản hồi tiêu cực, mức độ hài lòng và khiếu nại phát sinh tại một nơi.
            </p>
        </field>
    </record>

    <record id="action_customer_feedback_received" model="ir.actions.act_window">
        <field name="name">Phản hồi đã nhận</field>
        <field name="res_model">crm.service.feedback.request</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="domain">[('state', '=', 'answered')]</field>
        <field name="context">{'search_default_answered': 1}</field>
        <field name="search_view_id" ref="view_feedback_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có phản hồi nào từ khách hàng
            </p>
            <p>
                Khi khách hàng gửi biểu mẫu qua portal hoặc link email, phản hồi sẽ xuất hiện tại đây để nhân viên xem và trả lời lại.
            </p>
        </field>
    </record>

    <record id="action_feedback_analysis" model="ir.actions.act_window">
        <field name="name">Thống kê mức độ hài lòng</field>
        <field name="res_model">crm.service.feedback.request</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="domain">[('state', '=', 'answered')]</field>
        <field name="context">{'group_by': 'satisfaction_level'}</field>
    </record>
</odoo>
