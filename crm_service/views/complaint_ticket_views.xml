<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_complaint_ticket_list" model="ir.ui.view">
        <field name="name">crm.service.complaint.ticket.list</field>
        <field name="model">crm.service.complaint.ticket</field>
        <field name="arch" type="xml">
            <list string="Phiếu khiếu nại" decoration-danger="sla_status == 'late'" decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="title"/>
                <field name="customer_id"/>
                <field name="related_document_ref" optional="hide"/>
                <field name="severity" widget="badge" decoration-danger="severity == 'high'" decoration-warning="severity == 'medium'" decoration-info="severity == 'low'"/>
                <field name="state" widget="badge" decoration-muted="state == 'draft'" decoration-info="state == 'open'" decoration-warning="state == 'processing'" decoration-success="state in ('resolved', 'closed')"/>
                <field name="sale_user_id"/>
                <field name="assigned_user_id"/>
                <field name="deadline"/>
                <field name="sla_status" widget="badge" decoration-success="sla_status == 'on_time'" decoration-danger="sla_status == 'late'"/>
                <field name="feedback_request_id" optional="hide"/>
                <field name="satisfaction_score"/>
            </list>
        </field>
    </record>

    <record id="view_complaint_ticket_kanban" model="ir.ui.view">
        <field name="name">crm.service.complaint.ticket.kanban</field>
        <field name="model">crm.service.complaint.ticket</field>
        <field name="arch" type="xml">
            <kanban string="Bảng xử lý khiếu nại" default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="title"/>
                <field name="customer_id"/>
                <field name="severity"/>
                <field name="state"/>
                <field name="deadline"/>
                <field name="sla_status"/>
                <field name="assigned_user_id"/>
                <field name="sale_user_id"/>
                <field name="satisfaction_score"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="fw-bold text-primary" t-out="record.name.value"/>
                            <span t-if="record.sla_status.raw_value == 'late'" class="badge text-bg-danger">Trễ SLA</span>
                            <span t-elif="record.sla_status.raw_value == 'on_time'" class="badge text-bg-success">Đúng hạn</span>
                        </div>
                        <div class="fw-semibold mb-2" t-out="record.title.value"/>
                        <div class="text-muted small mb-3" t-if="record.customer_id.value">
                            <i class="fa fa-building-o me-1" title="Khách hàng"/>
                            <span t-out="record.customer_id.value"/>
                        </div>
                        <div class="d-flex flex-wrap gap-1 mb-3">
                            <span t-if="record.severity.raw_value == 'high'" class="badge text-bg-danger">Cao</span>
                            <span t-elif="record.severity.raw_value == 'medium'" class="badge text-bg-warning">Trung bình</span>
                            <span t-elif="record.severity.raw_value == 'low'" class="badge text-bg-info">Thấp</span>
                            <span t-if="record.state.raw_value == 'draft'" class="badge text-bg-secondary">Mới</span>
                            <span class="badge text-bg-light" t-if="record.assigned_user_id.value">
                                <i class="fa fa-user me-1" title="Người xử lý"/>
                                <span t-out="record.assigned_user_id.value"/>
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center small text-muted">
                            <span>
                                <i class="fa fa-clock-o me-1" title="Hạn SLA"/>
                                <field name="deadline"/>
                            </span>
                            <span t-if="record.satisfaction_score.raw_value">
                                <i class="fa fa-star text-warning me-1" title="Điểm hài lòng"/>
                                <span t-out="record.satisfaction_score.value"/>
                            </span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_complaint_ticket_form" model="ir.ui.view">
        <field name="name">crm.service.complaint.ticket.form</field>
        <field name="model">crm.service.complaint.ticket</field>
        <field name="arch" type="xml">
            <form string="Phiếu khiếu nại">
                <header>
                    <button name="action_accept" string="Tiếp nhận" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_processing" string="Bắt đầu xử lý" type="object" class="btn-primary" invisible="state != 'open'"/>
                    <button name="action_resolved" string="Đánh dấu đã xử lý" type="object" class="btn-primary" invisible="state not in ('open', 'processing')"/>
                    <button name="action_closed" string="Đóng" type="object" class="btn-primary" invisible="state not in ('resolved', 'processing')"/>
                    <button name="action_reopen" string="Mở lại" type="object" invisible="state in ('draft', 'open')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,processing,resolved,closed"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Trễ SLA" bg_color="text-bg-danger" invisible="sla_status != 'late'"/>
                    <field name="customer_can_edit" invisible="1"/>
                    <field name="customer_can_delete" invisible="1"/>
                    <div class="oe_title">
                        <span class="text-muted">
                            <field name="name"/>
                        </span>
                        <label for="title"/>
                        <h1>
                            <field name="title" placeholder="Tiêu đề khiếu nại"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Thông tin khách hàng">
                            <field name="name"/>
                            <field name="customer_id"/>
                            <field name="lead_id"/>
                            <field name="related_document_ref"/>
                            <field name="feedback_request_id"/>
                            <field name="sale_user_id"/>
                            <field name="assigned_user_id"/>
                        </group>
                        <group string="Thông tin SLA">
                            <field name="severity"/>
                            <field name="deadline"/>
                            <field name="accepted_date"/>
                            <field name="response_date"/>
                            <field name="resolved_date"/>
                            <field name="sla_status" widget="badge" decoration-success="sla_status == 'on_time'" decoration-danger="sla_status == 'late'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thông tin khiếu nại">
                            <field name="description" placeholder="Mô tả nội dung khiếu nại và phương án xử lý mong muốn"/>
                        </page>
                        <page string="Xử lý">
                            <group>
                                <field name="root_cause"/>
                                <field name="solution"/>
                                <field name="internal_note"/>
                            </group>
                        </page>
                        <page string="Phản hồi khách hàng">
                            <group>
                                <field name="satisfaction_score"/>
                                <field name="customer_feedback"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_complaint_ticket_search" model="ir.ui.view">
        <field name="name">crm.service.complaint.ticket.search</field>
        <field name="model">crm.service.complaint.ticket</field>
        <field name="arch" type="xml">
            <search string="Phiếu khiếu nại">
                <field name="name"/>
                <field name="title"/>
                <field name="customer_id"/>
                <field name="lead_id"/>
                <field name="sale_user_id"/>
                <field name="assigned_user_id"/>
                <filter name="late_sla" string="Trễ SLA" domain="[('sla_status', '=', 'late')]"/>
                <filter name="active_tickets" string="Đang mở" domain="[('state', 'in', ['draft', 'open', 'processing'])]"/>
                <filter name="draft" string="Mới" domain="[('state', '=', 'draft')]"/>
                <filter name="open" string="Đã tiếp nhận" domain="[('state', '=', 'open')]"/>
                <filter name="processing" string="Đang xử lý" domain="[('state', '=', 'processing')]"/>
                <filter name="resolved" string="Đã xử lý" domain="[('state', '=', 'resolved')]"/>
                <filter name="closed" string="Đã đóng" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter name="group_severity" string="Mức ưu tiên" context="{'group_by': 'severity'}"/>
                <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                <filter name="group_salesperson" string="Nhân viên kinh doanh" context="{'group_by': 'sale_user_id'}"/>
                <filter name="group_sla" string="Trạng thái SLA" context="{'group_by': 'sla_status'}"/>
                <filter name="group_customer" string="Khách hàng" context="{'group_by': 'customer_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_complaint_ticket_graph" model="ir.ui.view">
        <field name="name">crm.service.complaint.ticket.graph</field>
        <field name="model">crm.service.complaint.ticket</field>
        <field name="arch" type="xml">
            <graph string="Phân tích khiếu nại" type="bar">
                <field name="severity"/>
            </graph>
        </field>
    </record>

    <record id="view_complaint_ticket_pivot" model="ir.ui.view">
        <field name="name">crm.service.complaint.ticket.pivot</field>
        <field name="model">crm.service.complaint.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Phân tích khiếu nại">
                <field name="severity" type="row"/>
                <field name="state" type="col"/>
                <field name="satisfaction_score" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_complaint_ticket" model="ir.actions.act_window">
        <field name="name">Phiếu khiếu nại</field>
        <field name="res_model">crm.service.complaint.ticket</field>
        <field name="view_mode">kanban,list,form,graph,pivot</field>
        <field name="search_view_id" ref="view_complaint_ticket_search"/>
        <field name="context">{'search_default_active_tickets': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo phiếu khiếu nại khách hàng đầu tiên
            </p>
            <p>
                Theo dõi mức ưu tiên, hạn SLA, nguyên nhân gốc, giải pháp và mức độ hài lòng khách hàng trong một quy trình.
            </p>
        </field>
    </record>
</odoo>
