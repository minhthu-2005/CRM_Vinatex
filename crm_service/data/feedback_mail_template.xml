<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_template_feedback_request" model="mail.template">
        <field name="name">Yêu cầu phản hồi khách hàng</field>
        <field name="model_id" ref="model_crm_service_feedback_request"/>
        <field name="subject">Yêu cầu phản hồi: {{ object.form_id.name }}</field>
        <field name="email_from">{{ object.user_id.partner_id.email_formatted or object.company_id.email or '' }}</field>
        <field name="email_to">{{ object.email or object.partner_id.email or '' }}</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <div>
                <p>Xin chào <t t-out="object.partner_id.name or 'Quý khách'"/>,</p>
                <p>Vui lòng hoàn thành biểu mẫu phản hồi <strong><t t-out="object.form_id.name"/></strong>.</p>
                <p t-if="object.form_id.description">
                    <t t-out="object.form_id.description"/>
                </p>
                <p>
                    <a t-att-href="object.get_feedback_url()" style="display:inline-block;padding:10px 16px;background:#0d6efd;color:#ffffff;text-decoration:none;border-radius:4px;">
                        Mở biểu mẫu phản hồi
                    </a>
                </p>
                <p>Trân trọng cảm ơn.</p>
            </div>
        </field>
    </record>

    <record id="mail_template_feedback_staff_reply" model="mail.template">
        <field name="name">Trả lời phản hồi khách hàng</field>
        <field name="model_id" ref="model_crm_service_feedback_request"/>
        <field name="subject">{{ object.staff_reply_subject or ('Phản hồi từ ' + (object.company_id.name or 'Thục Linh') + ': ' + object.form_id.name) }}</field>
        <field name="email_from">{{ object.user_id.partner_id.email_formatted or object.company_id.email or '' }}</field>
        <field name="email_to">{{ object.email or object.partner_id.email or '' }}</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <div>
                <p>Xin chào <t t-out="object.partner_id.name or 'Quý khách'"/>,</p>
                <p>Chúng tôi đã ghi nhận phản hồi của anh/chị cho biểu mẫu <strong><t t-out="object.form_id.name"/></strong>.</p>
                <div style="padding:12px;border-left:4px solid #0d6efd;background:#f8f9fa;margin:12px 0;white-space:pre-line;">
                    <t t-out="object.staff_reply"/>
                </div>
                <p>
                    <a t-att-href="object.get_feedback_url()" style="display:inline-block;padding:10px 16px;background:#0d6efd;color:#ffffff;text-decoration:none;border-radius:4px;">
                        Xem lại phản hồi
                    </a>
                </p>
                <p>Trân trọng cảm ơn.</p>
            </div>
        </field>
    </record>
</odoo>
