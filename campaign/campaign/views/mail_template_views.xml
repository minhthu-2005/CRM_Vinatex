<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mail_template_search_campaign" model="ir.ui.view">
        <field name="name">mail.template.search.campaign</field>
        <field name="model">mail.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="T&#234;n Template"/>
                <field name="campaign_template_type" string="Lo&#7841;i Template"/>
                <filter name="filter_campaign_template" string="D&#249;ng cho Campaign" domain="[('is_campaign_template','=',True)]"/>
                <filter name="filter_remarketing" string="Remarketing" domain="[('campaign_template_type','=','remarketing')]"/>
                <filter name="filter_followup" string="Ch&#259;m s&#243;c l&#7841;i" domain="[('campaign_template_type','=','follow_up')]"/>
                <filter name="group_template_type" string="Lo&#7841;i Template" context="{'group_by':'campaign_template_type'}"/>
            </search>
        </field>
    </record>

    <record id="view_mail_template_list_campaign" model="ir.ui.view">
        <field name="name">mail.template.list.campaign</field>
        <field name="model">mail.template</field>
        <field name="priority" eval="99"/>
        <field name="arch" type="xml">
            <tree string="Mẫu email cho chiến dịch">
                <field name="name" string="T&#234;n Template"/>
                <field name="campaign_template_type" string="Lo&#7841;i Template"/>
                <field name="is_campaign_template" string="D&#249;ng cho Campaign"/>
                <field name="campaign_usage_status" string="Tr&#7841;ng th&#225;i s&#7917; d&#7909;ng" widget="badge"
                       decoration-success="campaign_usage_status == 'active'"
                       decoration-muted="campaign_usage_status == 'inactive'"/>
            </tree>
        </field>
    </record>

    <record id="view_mail_template_form_campaign" model="ir.ui.view">
        <field name="name">mail.template.form.campaign</field>
        <field name="model">mail.template</field>
        <field name="inherit_id" ref="mail.email_template_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='model_id']" position="after">
                <field name="is_campaign_template" string="D&#249;ng cho Campaign"/>
                <field name="campaign_template_type" string="Lo&#7841;i Template" invisible="not is_campaign_template"/>
            </xpath>
        </field>
    </record>
</odoo>
