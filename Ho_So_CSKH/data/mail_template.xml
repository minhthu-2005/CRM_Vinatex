<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- KẾ THỪA MODULE MAIL -->
    <!-- Model mail.template -->
    <!-- CUSTOM THÊM MỚI -->
    <!-- Template email quy trình mặc định cho Hồ sơ CSKH -->
    <record id="email_template_workflow_followup" model="mail.template">
        <field name="name">Email quy trình chăm sóc tiếp CSKH</field>
        <field name="model_id" ref="model_crm_cskh_profile"/>
        <field name="subject">Cập nhật chăm sóc khách hàng từ {{ object.lead_id.name or 'CRM' }}</field>
        <field name="email_from">{{ user.email or '' }}</field>
        <field name="email_to">{{ object.customer_id.email or '' }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Xin chào <t t-out="object.customer_id.name or 'Quý khách'"/>,</p>
                <p>Đội ngũ kinh doanh đang tiếp tục theo dõi và chăm sóc nhu cầu của Quý khách.</p>
                <p>
                    <b>Hành động tiếp theo:</b>
                    <t t-out="object.next_action or ''"/>
                </p>
                <p>
                    <b>Hạn chăm sóc tiếp theo:</b>
                    <t t-out="object.followup_deadline or ''"/>
                </p>
                <p>Trân trọng.</p>
            </div>
        </field>
    </record>

    <!-- KẾ THỪA MODULE MAIL -->
    <!-- Model mail.template -->
    <!-- CUSTOM THÊM MỚI -->
    <!-- Template email xác nhận nhu cầu khách hàng -->
    <record id="email_template_need_confirmation" model="mail.template">
        <field name="name">Email xác nhận nhu cầu khách hàng</field>
        <field name="model_id" ref="model_crm_cskh_profile"/>
        <field name="subject">Xác nhận nhu cầu sản phẩm của {{ object.customer_id.name or 'Quý khách' }}</field>
        <field name="email_from">{{ user.email or '' }}</field>
        <field name="email_to">{{ object.customer_id.email or '' }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Xin chào <t t-out="object.customer_id.name or 'Quý khách'"/>,</p>
                <p>Cảm ơn Quý khách đã trao đổi nhu cầu với đội ngũ kinh doanh.</p>
                <p>
                    <b>Nhu cầu ghi nhận:</b>
                    <t t-out="object.customer_need or object.content or ''"/>
                </p>
                <p>
                    <b>Chủng loại sản phẩm:</b>
                    <t t-out="object.product_category or ''"/>
                </p>
                <p>Chúng tôi sẽ tiếp tục xác nhận thông tin chi tiết và phản hồi bước tiếp theo.</p>
                <p>Trân trọng.</p>
            </div>
        </field>
    </record>

    <!-- KẾ THỪA MODULE MAIL -->
    <!-- Model mail.template -->
    <!-- CUSTOM THÊM MỚI -->
    <!-- Template email theo dõi phản hồi báo giá -->
    <record id="email_template_quotation_followup" model="mail.template">
        <field name="name">Email theo dõi phản hồi báo giá</field>
        <field name="model_id" ref="model_crm_cskh_profile"/>
        <field name="subject">Theo dõi phản hồi báo giá - {{ object.lead_id.name or 'CRM' }}</field>
        <field name="email_from">{{ user.email or '' }}</field>
        <field name="email_to">{{ object.customer_id.email or '' }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Xin chào <t t-out="object.customer_id.name or 'Quý khách'"/>,</p>
                <p>Chúng tôi gửi email này để theo dõi phản hồi của Quý khách về báo giá/đề xuất đã trao đổi.</p>
                <p>
                    <b>Hành động tiếp theo:</b>
                    <t t-out="object.next_action or ''"/>
                </p>
                <p>
                    <b>Hạn chăm sóc tiếp theo:</b>
                    <t t-out="object.followup_deadline or ''"/>
                </p>
                <p>Rất mong nhận được phản hồi từ Quý khách.</p>
                <p>Trân trọng.</p>
            </div>
        </field>
    </record>

    <!-- KẾ THỪA MODULE MAIL -->
    <!-- Model mail.template -->
    <!-- CUSTOM THÊM MỚI -->
    <!-- Template email chăm sóc khách hàng sau bán -->
    <record id="email_template_after_sales_care" model="mail.template">
        <field name="name">Email chăm sóc sau bán</field>
        <field name="model_id" ref="model_crm_cskh_profile"/>
        <field name="subject">Chăm sóc sau bán - {{ object.customer_id.name or 'Quý khách' }}</field>
        <field name="email_from">{{ user.email or '' }}</field>
        <field name="email_to">{{ object.customer_id.email or '' }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Xin chào <t t-out="object.customer_id.name or 'Quý khách'"/>,</p>
                <p>Chúng tôi mong muốn kiểm tra mức độ hài lòng của Quý khách sau quá trình làm việc/giao dịch.</p>
                <p>
                    <b>Nội dung chăm sóc tiếp theo:</b>
                    <t t-out="object.next_action or ''"/>
                </p>
                <p>Nếu có phản hồi hoặc nhu cầu hỗ trợ thêm, Quý khách có thể phản hồi trực tiếp email này.</p>
                <p>Trân trọng.</p>
            </div>
        </field>
    </record>

</odoo>
